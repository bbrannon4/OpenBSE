!-~~~~ Building_tmpl ~~~

  Sizing:Parameters,
    1.25,                    !- Heating Sizing Factor
    1.15,                    !- Cooling Sizing Factor
    6;                       !- Timesteps in Averaging Window

  Output:Diagnostics,
    DisplayExtraWarnings;    !- Key 1

  Curve:Bicubic,
    CondensingBoiler_Perf_One_Boiler,  !- Name
    0.946581,                !- Coefficient1 Constant
    0.022541,                !- Coefficient2 x
    -3.1E-15,                !- Coefficient3 x**2
    0.00904,                 !- Coefficient4 y
    -0.00029,                !- Coefficient5 y**2
    -0.00176,                !- Coefficient6 x*y
    -0.03203,                !- Coefficient7 x**3
    2.15E-06,                !- Coefficient8 y**3
    0.000827,                !- Coefficient9 x**2*y
    1.40464E-05,             !- Coefficient10 x*y**2
    0,                       !- Minimum Value of x
    1,                       !- Maximum Value of x
    21.1,                    !- Minimum Value of y
    71,                      !- Maximum Value of y
    ,                        !- Minimum Curve Output
    ,                        !- Maximum Curve Output
    Dimensionless,           !- Input Unit Type for X
    Dimensionless,           !- Input Unit Type for Y
    Dimensionless;           !- Output Unit Type

