  EnergyManagementSystem:ProgramCallingManager,
    Door_Switch_Enabled_Thermostat_Reset,  !- Name
    BeginTimestepBeforePredictor,  !- EnergyPlus Model Calling Point
    Door_Switch_Enabled_Thermostat_Reset_Program_N_LivingUnit,  !- Program Name 1
    Door_Switch_Enabled_Thermostat_Reset_Program_S_LivingUnit;  !- Program Name 2

  EnergyManagementSystem:GlobalVariable,
    timesteps_after_doorshut_south;  !- Erl Variable 1 Name

  EnergyManagementSystem:GlobalVariable,
    timesteps_after_doorshut_north;  !- Erl Variable 1 Name

  EnergyManagementSystem:Program,
    init_timesteps_after_doorshut,  !- Name
    SET timesteps_after_doorshut_south = 0,  !- Program Line 1
    SET timesteps_after_doorshut_north = 0;  !- Program Line 2

  EnergyManagementSystem:OutputVariable,
    timesteps_after_doorshut_south,  !- Name
    timesteps_after_doorshut_south,  !- EMS Variable Name
    Averaged,                !- Type of Data in Variable
    ZoneTimeStep,            !- Update Frequency
    ,                        !- EMS Program or Subroutine Name
    ;                        !- Units

  EnergyManagementSystem:OutputVariable,
    timesteps_after_doorshut_north,  !- Name
    timesteps_after_doorshut_north,  !- EMS Variable Name
    Averaged,                !- Type of Data in Variable
    ZoneTimeStep,            !- Update Frequency
    ,                        !- EMS Program or Subroutine Name
    ;                        !- Units

  EnergyManagementSystem:ProgramCallingManager,
    init_timesteps_after_doorshut_south_Program Manager,  !- Name
    BeginNewEnvironment,     !- EnergyPlus Model Calling Point
    init_timesteps_after_doorshut;  !- Program Name 1

  EnergyManagementSystem:Program,
    Door_Switch_Enabled_Thermostat_Reset_Program_S_LivingUnit,  !- Name
    IF (S_Sliding_Door_Ventilation_Sensor > 0),  !- Program Line 1
    SET timesteps_after_doorshut_south = 0,  !- Program Line 2
    SET S_LivingUnit_CLGSETP_Actuator = 32.22,  !- <none>
    SET S_LivingUnit_HTGSETP_Actuator = 12.78,  !- <none>
    ELSEIF S_LivingUnit_CLGSETP_Actuator > 24.4,  !- <none>
    SET timesteps_after_doorshut_south = timesteps_after_doorshut_south + 1,  !- <none>
    IF timesteps_after_doorshut_south == 1,  !- <none>
    SET S_LivingUnit_CLGSETP_Actuator = 30,  !- <none>
    SET S_LivingUnit_HTGSETP_Actuator = 14,  !- <none>
    ELSEIF timesteps_after_doorshut_south == 2,  !- <none>
    SET S_LivingUnit_CLGSETP_Actuator = 28,  !- <none>
    SET S_LivingUnit_HTGSETP_Actuator = 16,  !- <none>
    ELSEIF timesteps_after_doorshut_south == 3,  !- <none>
    SET S_LivingUnit_CLGSETP_Actuator = 26,  !- <none>
    SET S_LivingUnit_HTGSETP_Actuator = 18,  !- <none>
    ELSEIF timesteps_after_doorshut_south == 4,  !- <none>
    SET S_LivingUnit_CLGSETP_Actuator = 25,  !- <none>
    SET S_LivingUnit_HTGSETP_Actuator = 20,  !- <none>
    SET S_LivingUnit_CLGSETP_Actuator = null,  !- <none>
    SET S_LivingUnit_HTGSETP_Actuator = null,  !- <none>
    ENDIF,                   !- <none>
    ELSE,                    !- <none>
    SET timesteps_after_doorshut_south = 0,  !- <none>
    SET S_LivingUnit_CLGSETP_Actuator = null,  !- <none>
    SET S_LivingUnit_HTGSETP_Actuator = null,  !- <none>
    ENDIF;                   !- <none>

  EnergyManagementSystem:Program,
    Door_Switch_Enabled_Thermostat_Reset_Program_N_LivingUnit,  !- Name
    IF (N_Sliding_Door_Ventilation_Sensor > 0),  !- Program Line 1
    SET timesteps_after_doorshut_north = 0,  !- Program Line 2
    SET N_LivingUnit_CLGSETP_Actuator = 32.22,  !- <none>
    SET N_LivingUnit_HTGSETP_Actuator = 12.78,  !- <none>
    ELSEIF N_LivingUnit_CLGSETP_Actuator > 24.4,  !- <none>
    SET timesteps_after_doorshut_north = timesteps_after_doorshut_north + 1,  !- <none>
    IF timesteps_after_doorshut_north == 1,  !- <none>
    SET N_LivingUnit_CLGSETP_Actuator = 30,  !- <none>
    SET N_LivingUnit_HTGSETP_Actuator = 14,  !- <none>
    ELSEIF timesteps_after_doorshut_north == 2,  !- <none>
    SET N_LivingUnit_CLGSETP_Actuator = 28,  !- <none>
    SET N_LivingUnit_HTGSETP_Actuator = 16,  !- <none>
    ELSEIF timesteps_after_doorshut_north == 3,  !- <none>
    SET N_LivingUnit_CLGSETP_Actuator = 26,  !- <none>
    SET N_LivingUnit_HTGSETP_Actuator = 18,  !- <none>
    ELSEIF timesteps_after_doorshut_north == 4,  !- <none>
    SET N_LivingUnit_CLGSETP_Actuator = 25,  !- <none>
    SET N_LivingUnit_HTGSETP_Actuator = 20,  !- <none>
    SET N_LivingUnit_CLGSETP_Actuator = null,  !- <none>
    SET N_LivingUnit_HTGSETP_Actuator = null,  !- <none>
    ENDIF,                   !- <none>
    ELSE,                    !- <none>
    SET timesteps_after_doorshut_north = 0,  !- <none>
    SET N_LivingUnit_CLGSETP_Actuator = null,  !- <none>
    SET N_LivingUnit_HTGSETP_Actuator = null,  !- <none>
    ENDIF;                   !- <none>

  EnergyManagementSystem:GlobalVariable,
    BoilerType,              !- Erl Variable 1 Name
    CapRated,                !- Erl Variable 2 Name
    EtRated,                 !- Erl Variable 3 Name
    PLRx,                    !- <none>
    Ecx,                     !- <none>
    SkinLossRate;            !- <none>

  EnergyManagementSystem:Sensor,
    BoilerPLR,               !- Name
    HeatSys1 Boiler,         !- Output:Variable or Output:Meter Index Key Name
    Boiler Part Load Ratio;  !- Output:Variable or Output:Meter Name

  EnergyManagementSystem:Actuator,
    BoilerCurve,             !- Name
    HeatSys1 BOILER EFFICIENCY CURVE,  !- Actuated Component Unique Name
    Curve,                   !- Actuated Component Type
    Curve Result;            !- Actuated Component Control Type

  EnergyManagementSystem:Program,
    SetBoilerPar,            !- Name
    SET CapRated =  150456.61,  !- Program Line 1
    SET EtRated =  0.75,     !- Program Line 2
    SET CapRated = (CapRated *3.412)/1000,  !- <none>
    SET SkinLossRate = 0.02, !- <none>
    SET BoilerType = 2,      !- <none>
    IF BoilerType  == 1,     !- <none>
    IF CapRated >10000,      !- <none>
    SET PLRx = 0.2,          !- <none>
    ELSEIF CapRated >5000,   !- <none>
    SET PLRx = 0.25,         !- <none>
    ELSEIF CapRated >1000,   !- <none>
    SET PLRx = 0.33,         !- <none>
    ELSE,                    !- <none>
    SET BoilerType = 2,      !- <none>
    SET PLRx = 0.2,          !- <none>
    ENDIF,                   !- <none>
    ELSE,                    !- <none>
    SET PLRx = 0.2,          !- <none>
    ENDIF,                   !- <none>
    IF BoilerType == 1,      !- <none>
    SET CurveX = 0.975 + 0.305 * PLRx - 0.527 * (PLRx^2) + 0.249 * (PLRx^3),  !- <none>
    ELSEIF BoilerType == 2,  !- <none>
    SET CurveX = 0.907 + 0.320 * PLRx - 0.420 * (PLRx^2) + 0.193 * (PLRx^3),  !- <none>
    ELSE,                    !- <none>
    SET CurveX = 0.492 + 1.41 * PLRx - 1.529 * (PLRx^2) + 0.628 * (PLRx^3),  !- <none>
    ENDIF,                   !- <none>
    SET LoadX = CapRated * PLRx,  !- <none>
    SET Etx = CurveX * EtRated,  !- <none>
    SET InputEx = LoadX/Etx, !- <none>
    SET SkinEx = CapRated * SkinLossRate,  !- <none>
    SET Ecx = (LoadX + SkinEx)/InputEx;  !- <none>

  EnergyManagementSystem:Program,
    SetBoilerCurve,          !- Name
    IF BoilerPLR >= PLRx,    !- Program Line 1
    IF BoilerType == 1,      !- Program Line 2
    SET BoilerCurve = 0.975 + 0.305*BoilerPLR - 0.527*(BoilerPLR^2) + 0.249*(BoilerPLR^3),  !- <none>
    ELSEIF BoilerType == 2,  !- <none>
    SET BoilerCurve = 0.907 + 0.320*BoilerPLR - 0.420*(BoilerPLR^2) + 0.193*(BoilerPLR^3),  !- <none>
    ELSE,                    !- <none>
    SET BoilerCurve = 0.492 + 1.41*BoilerPLR - 1.529*(BoilerPLR^2) + 0.628*(BoilerPLR^3),  !- <none>
    ENDIF,                   !- <none>
    ELSE,                    !- <none>
    IF BoilerPLR == 0,       !- <none>
    SET BoilerCurve = NULL,  !- <none>
    ELSE,                    !- <none>
    IF BoilerPLR <0.05,      !- <none>
    SET BoilerCurve = (0.05/(0.05 + SkinLossRate)) * (Ecx/EtRated),  !- <none>
    ELSE,                    !- <none>
    SET BoilerCurve = (BoilerPLR/(BoilerPLR + SkinLossRate)) * (Ecx/EtRated),  !- <none>
    ENDIF,                   !- <none>
    ENDIF,                   !- <none>
    ENDIF;                   !- <none>

  EnergyManagementSystem:ProgramCallingManager,
    BoilerParManager,        !- Name
    BeginNewEnvironment,     !- EnergyPlus Model Calling Point
    SetBoilerPar;            !- Program Name 1

  EnergyManagementSystem:ProgramCallingManager,
    BoilerCurveManager,      !- Name
    InsideHVACSystemIterationLoop,  !- EnergyPlus Model Calling Point
    SetBoilerCurve;          !- Program Name 1

